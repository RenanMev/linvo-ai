generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  disabled
}

enum IdentityKind {
  document
  email
  name_context
  phone
  protocol
}

enum CaseKind {
  protocol
  subject_context
}

enum ConfirmationStatus {
  not_required
  low_confidence
  pending_confirmation
  known
  accepted
  rejected
}

enum CustomerAiMessageRole {
  user
  assistant
}

enum CustomerAiMessageStatus {
  completed
  streaming
  interrupted
  error
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  email               String               @unique
  passwordHash        String
  name                String?
  status              UserStatus           @default(active)
  createdAt           DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @db.Timestamptz(6)
  customers           Customer[]
  customerCases       CustomerCase[]
  customerAiThreads   CustomerAiThread[]
  customerDomPatterns CustomerDomPattern[]
  identificationRuns  IdentificationRun[]
  passwordResetTokens  PasswordResetToken[]
  refreshSessions     RefreshSession[]
  siteAgentContexts   SiteAgentContext[]
}

model RefreshSession {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  userAgent String?
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  expiresAt DateTime  @db.Timestamptz(6)
  revokedAt DateTime? @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  expiresAt DateTime  @db.Timestamptz(6)
  usedAt    DateTime? @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Customer {
  id                 String               @id @default(uuid()) @db.Uuid
  userId             String               @db.Uuid
  domain             String
  identityHash       String
  identityKind       IdentityKind
  displayName        String?
  notes              String?              @db.Text
  maskedIdentifiers  Json                 @default("{}")
  isStarred          Boolean              @default(false)
  favoriteFieldsJson Json                 @default("[]")
  confidence         Decimal              @db.Decimal(4, 3)
  firstSeenAt        DateTime             @default(now()) @db.Timestamptz(6)
  lastSeenAt         DateTime             @default(now()) @db.Timestamptz(6)
  createdAt          DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime             @updatedAt @db.Timestamptz(6)
  aiThread           CustomerAiThread?
  cases              CustomerCase[]
  domPatterns        CustomerDomPattern[]
  identificationRuns IdentificationRun[]
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain, identityHash])
  @@index([userId, domain, lastSeenAt])
}

model CustomerAiThread {
  id                       String              @id @default(uuid()) @db.Uuid
  userId                   String              @db.Uuid
  customerId               String              @unique @db.Uuid
  summary                  String?             @db.Text
  messageCountSinceSummary Int                 @default(0)
  createdAt                DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime            @updatedAt @db.Timestamptz(6)
  customer                 Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messages                 CustomerAiMessage[]
  user                     User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model CustomerAiMessage {
  id        String                  @id @default(uuid()) @db.Uuid
  threadId  String                  @db.Uuid
  role      CustomerAiMessageRole
  content   String                  @db.Text
  status    CustomerAiMessageStatus @default(completed)
  sequence  Int
  createdAt DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt DateTime                @updatedAt @db.Timestamptz(6)
  thread    CustomerAiThread        @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, sequence])
  @@index([threadId, sequence])
}

model CustomerCase {
  id                 String              @id @default(uuid()) @db.Uuid
  userId             String              @db.Uuid
  customerId         String?             @db.Uuid
  domain             String
  caseHash           String
  caseKind           CaseKind
  protocolDisplay    String?
  subjectDisplay     String?
  statusDisplay      String?
  confidence         Decimal             @db.Decimal(4, 3)
  firstSeenAt        DateTime            @default(now()) @db.Timestamptz(6)
  lastSeenAt         DateTime            @default(now()) @db.Timestamptz(6)
  createdAt          DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @db.Timestamptz(6)
  customer           Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  identificationRuns IdentificationRun[]
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain, caseHash])
  @@index([userId, domain, lastSeenAt])
}

model CustomerDomPattern {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  customerId     String   @db.Uuid
  domain         String
  patternHash    String
  anchorText     String?
  nameText       String?
  identifierText String?
  signatureJson  Json     @default("{}")
  lastSeenAt     DateTime @default(now()) @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @db.Timestamptz(6)
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain, patternHash])
  @@index([customerId])
  @@index([userId, domain, lastSeenAt])
}

model IdentificationRun {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @db.Uuid
  customerId         String?       @db.Uuid
  customerCaseId     String?       @db.Uuid
  requestId          String
  domain             String
  pageUrlHash        String
  selectedLabel      String?
  confidence         Decimal       @db.Decimal(4, 3)
  saved              Boolean       @default(false)
  candidateJson      Json          @default("{}")
  domSignatureJson   Json          @default("{}")
  confirmationStatus ConfirmationStatus @default(not_required)
  confirmedAt        DateTime?     @db.Timestamptz(6)
  bulkBatchId        String?
  bulkItemIndex      Int?
  evidenceJson       Json          @default("[]")
  warningsJson       Json          @default("[]")
  durationMs         Int?
  createdAt          DateTime      @default(now()) @db.Timestamptz(6)
  customer           Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerCase       CustomerCase? @relation(fields: [customerCaseId], references: [id], onDelete: SetNull)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteAgentContexts  SiteAgentContext[] @relation("SiteContextSourceRun")

  @@unique([userId, requestId])
  @@index([userId, domain, createdAt])
  @@index([userId, domain, bulkBatchId])
}

model SiteAgentContext {
  id              String             @id @default(uuid()) @db.Uuid
  userId          String             @db.Uuid
  domain          String
  summary         String             @db.Text
  regionsJson     Json               @default("[]")
  focusRulesJson  Json               @default("[]")
  ignoreRulesJson Json               @default("[]")
  confidence      Decimal            @db.Decimal(4, 3)
  sourceRequestId String
  sourceRunId     String?            @db.Uuid
  createdAt       DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @db.Timestamptz(6)
  sourceRun       IdentificationRun? @relation("SiteContextSourceRun", fields: [sourceRunId], references: [id], onDelete: SetNull)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain])
  @@index([userId, updatedAt])
  @@index([sourceRunId])
}
